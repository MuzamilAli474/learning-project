# Template: copy to .env.development, .env.qa, .env.staging, or .env.production
# Loaded file: .env.${NODE_ENV} (see src/config/index.js)

NODE_ENV=development

# HTTP
PORT=3000

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017/your-database-name

# JWT — production: set JWT_ACCESS_SECRET and JWT_REFRESH_SECRET to different long random strings.
# If unset, JWT_SECRET is used for both (OK for local dev; tokens still use a "type" claim).
JWT_SECRET=change-me-to-a-long-random-string
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=7d

# SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@example.com
